{
  "$description": "Perpetua tokens in W3C Design Tokens format — the machine-readable source of truth. Dark theme values; light theme lives in colors.css [data-theme=light]. Feed to Style Dictionary to emit CSS vars, Tailwind config, Swift, Kotlin, etc.",
  "color": {
    "bg": {
      "0": { "$type": "color", "$value": "#0b0c0e" },
      "1": { "$type": "color", "$value": "#111316" },
      "2": { "$type": "color", "$value": "#17191c" },
      "3": { "$type": "color", "$value": "#1e2125" }
    },
    "border": {
      "default": { "$type": "color", "$value": "#232528" },
      "strong": { "$type": "color", "$value": "#2e3136" }
    },
    "fg": {
      "0": { "$type": "color", "$value": "#f0f1f2" },
      "1": { "$type": "color", "$value": "#9ca3af" },
      "2": { "$type": "color", "$value": "#6b7280" },
      "3": { "$type": "color", "$value": "#3f4650" }
    },
    "accent": {
      "default": { "$type": "color", "$value": "#2dd4bf" },
      "strong": { "$type": "color", "$value": "#14b8a6" },
      "dim": { "$type": "color", "$value": "#134e4a" },
      "ink": { "$type": "color", "$value": "#042f2e" },
      "wash": { "$type": "color", "$value": "rgba(45, 212, 191, 0.08)" }
    },
    "market": {
      "long": { "$type": "color", "$value": "#34d399" },
      "long-wash": { "$type": "color", "$value": "rgba(52, 211, 153, 0.1)" },
      "short": { "$type": "color", "$value": "#f87171" },
      "short-wash": { "$type": "color", "$value": "rgba(248, 113, 113, 0.1)" }
    },
    "health": {
      "safe": { "$type": "color", "$value": "{color.market.long}" },
      "warn": { "$type": "color", "$value": "#fbbf24" },
      "danger": { "$type": "color", "$value": "{color.market.short}" }
    }
  },
  "font": {
    "display": { "$type": "fontFamily", "$value": ["Newsreader", "Georgia", "serif"] },
    "mono": { "$type": "fontFamily", "$value": ["IBM Plex Mono", "SF Mono", "Menlo", "ui-monospace", "monospace"] }
  },
  "typography": {
    "display-xl": { "$type": "typography", "$value": { "fontFamily": "{font.display}", "fontWeight": 300, "fontSize": "64px", "lineHeight": "1.08" } },
    "display-lg": { "$type": "typography", "$value": { "fontFamily": "{font.display}", "fontWeight": 300, "fontSize": "44px", "lineHeight": "1.15" } },
    "display-md": { "$type": "typography", "$value": { "fontFamily": "{font.display}", "fontWeight": 400, "fontSize": "30px", "lineHeight": "1.25" } },
    "display-sm": { "$type": "typography", "$value": { "fontFamily": "{font.display}", "fontWeight": 400, "fontSize": "22px", "lineHeight": "1.35" } },
    "mono-lg": { "$type": "typography", "$value": { "fontFamily": "{font.mono}", "fontWeight": 500, "fontSize": "16px", "lineHeight": "1.4" } },
    "mono-md": { "$type": "typography", "$value": { "fontFamily": "{font.mono}", "fontWeight": 400, "fontSize": "13px", "lineHeight": "1.5" } },
    "mono-sm": { "$type": "typography", "$value": { "fontFamily": "{font.mono}", "fontWeight": 400, "fontSize": "12px", "lineHeight": "1.45" } },
    "mono-xs": { "$type": "typography", "$value": { "fontFamily": "{font.mono}", "fontWeight": 400, "fontSize": "11px", "lineHeight": "1.4" } },
    "mono-2xs": { "$type": "typography", "$value": { "fontFamily": "{font.mono}", "fontWeight": 400, "fontSize": "10px", "lineHeight": "1.3" } }
  },
  "tracking": {
    "label": { "$type": "dimension", "$value": "0.12em" },
    "wide": { "$type": "dimension", "$value": "0.14em" }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "2px" },
    "2": { "$type": "dimension", "$value": "4px" },
    "3": { "$type": "dimension", "$value": "8px" },
    "4": { "$type": "dimension", "$value": "12px" },
    "5": { "$type": "dimension", "$value": "16px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "7": { "$type": "dimension", "$value": "32px" },
    "8": { "$type": "dimension", "$value": "48px" },
    "9": { "$type": "dimension", "$value": "64px" }
  },
  "size": {
    "row": { "$type": "dimension", "$value": "24px" },
    "control": { "$type": "dimension", "$value": "28px" }
  },
  "radius": {
    "default": { "$type": "dimension", "$value": "0px" }
  },
  "duration": {
    "fast": { "$type": "duration", "$value": "100ms" },
    "med": { "$type": "duration", "$value": "150ms" },
    "flash": { "$type": "duration", "$value": "600ms" }
  },
  "ease": {
    "default": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] }
  }
}
