{
  "$description": "Perpetua tokens in W3C Design Tokens format. Feed to Style Dictionary to emit CSS vars, Tailwind config, Swift, Kotlin, etc. tokens.css is generated from this file.",
  "color": {
    "surface": {
      "0": { "$type": "color", "$value": "#0a0b0e" },
      "1": { "$type": "color", "$value": "#101218" },
      "2": { "$type": "color", "$value": "#171a22" },
      "3": { "$type": "color", "$value": "#1f232e" }
    },
    "border": {
      "subtle": { "$type": "color", "$value": "#232733" },
      "strong": { "$type": "color", "$value": "#323848" }
    },
    "text": {
      "primary": { "$type": "color", "$value": "#e8eaf0" },
      "secondary": { "$type": "color", "$value": "#9aa2b5" },
      "muted": { "$type": "color", "$value": "#5d6578" },
      "inverse": { "$type": "color", "$value": "#0a0b0e" }
    },
    "accent": {
      "default": { "$type": "color", "$value": "#5b8cff" },
      "hover": { "$type": "color", "$value": "#7aa2ff" }
    },
    "trading": {
      "long": { "$type": "color", "$value": "#16c784" },
      "long-hover": { "$type": "color", "$value": "#1fdd95" },
      "short": { "$type": "color", "$value": "#ea3943" },
      "short-hover": { "$type": "color", "$value": "#f25560" },
      "flat": { "$type": "color", "$value": "#9aa2b5" }
    },
    "status": {
      "warn": { "$type": "color", "$value": "#f0b90b" },
      "danger": { "$type": "color", "$value": "{color.trading.short}" },
      "success": { "$type": "color", "$value": "{color.trading.long}" },
      "info": { "$type": "color", "$value": "{color.accent.default}" }
    }
  },
  "font": {
    "ui": { "$type": "fontFamily", "$value": ["Inter", "SF Pro", "system-ui", "sans-serif"] },
    "num": { "$type": "fontFamily", "$value": ["IBM Plex Mono", "SF Mono", "ui-monospace", "monospace"] }
  },
  "fontSize": {
    "2xs": { "$type": "dimension", "$value": "0.6875rem" },
    "xs": { "$type": "dimension", "$value": "0.75rem" },
    "sm": { "$type": "dimension", "$value": "0.8125rem" },
    "md": { "$type": "dimension", "$value": "0.9375rem" },
    "lg": { "$type": "dimension", "$value": "1.125rem" },
    "xl": { "$type": "dimension", "$value": "1.5rem" }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "0.75rem" },
    "4": { "$type": "dimension", "$value": "1rem" },
    "5": { "$type": "dimension", "$value": "1.5rem" },
    "6": { "$type": "dimension", "$value": "2rem" },
    "8": { "$type": "dimension", "$value": "3rem" }
  },
  "size": {
    "row": { "$type": "dimension", "$value": "1.5rem" },
    "control": { "$type": "dimension", "$value": "2rem" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "6px" },
    "lg": { "$type": "dimension", "$value": "10px" },
    "full": { "$type": "dimension", "$value": "999px" }
  },
  "duration": {
    "fast": { "$type": "duration", "$value": "100ms" },
    "med": { "$type": "duration", "$value": "180ms" },
    "slow": { "$type": "duration", "$value": "300ms" },
    "flash": { "$type": "duration", "$value": "300ms" }
  },
  "ease": {
    "default": { "$type": "cubicBezier", "$value": [0.25, 0.8, 0.25, 1] }
  }
}
